{
  "name": "mimic",
  "version": "0.1.0",
  "description": "基于 jsdom 的浏览器环境伪装框架 —— Profile/traits 驱动,面向 JS 逆向反检测",
  "type": "module",
  "main": "entry/index.js",
  "exports": {
    ".": "./entry/index.js"
  },
  "bin": {
    "mimic": "entry/cli.js"
  },
  "files": [
    "entry/",
    "core/",
    "mask/",
    "patch/",
    "base/",
    "trace/",
    "capture/",
    "harness/",
    "profiles/",
    "scripts/",
    "tools/",
    "README.md"
  ],
  "scripts": {
    "mimic": "node entry/cli.js",
    "smoke": "node smoke.js",
    "diff": "node entry/cli.js diff",
    "baseline": "node entry/cli.js baseline",
    "gen:keyorder": "node harness/gen-keyorder.mjs",
    "fp-env:adapt": "node tools/fp-env/adapt.mjs",
    "fp-env:verify": "node tools/fp-env/verify.mjs",
    "test": "node scripts/test.js"
  },
  "keywords": [
    "jsdom",
    "browser-environment",
    "fingerprint",
    "anti-detection",
    "js-reverse"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "jsdom": "29.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
