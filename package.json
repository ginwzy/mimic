{
  "name": "mimic",
  "version": "0.1.0",
  "description": "基于 jsdom 的浏览器环境伪装框架 —— Profile/traits 驱动,面向 JS 逆向反检测",
  "type": "module",
  "main": "entry/index.js",
  "exports": {
    ".": "./entry/index.js"
  },
  "bin": {
    "mimic": "entry/cli.js"
  },
  "files": [
    "entry/",
    "core/",
    "mask/",
    "patch/",
    "base/",
    "trace/",
    "capture/",
    "harness/",
    "profiles/",
    "scripts/",
    "tools/",
    "smoke.js",
    "README.md"
  ],
  "scripts": {
    "mimic": "node entry/cli.js",
    "smoke": "node smoke.js",
    "diff": "node entry/cli.js diff",
    "baseline": "node entry/cli.js baseline",
    "gen:keyorder": "node harness/gen-keyorder.mjs",
    "fp-env:adapt": "node tools/fp-env/adapt.mjs",
    "fp-env:verify": "node tools/fp-env/verify.mjs",
    "oracle:v1": "node scripts/v1-oracle.js",
    "bench:v1": "node scripts/v1-bench.js",
    "build:v2": "tsc -p tsconfig.v2.json",
    "typecheck:v2": "tsc -p tsconfig.v2.json --noEmit",
    "test:v2": "npm run build:v2 && node --test build/v2/test/v2/*.test.js",
    "test:legacy": "node scripts/test.js",
    "check:legacy": "node scripts/check.js",
    "check": "npm run typecheck:v2 && npm run check:legacy",
    "test": "npm run test:v2 && npm run test:legacy"
  },
  "keywords": [
    "jsdom",
    "browser-environment",
    "fingerprint",
    "anti-detection",
    "js-reverse"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "ajv": "8.20.0",
    "jsdom": "29.1.1"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24.0.0"
  },
  "devDependencies": {
    "@types/jsdom": "28.0.3",
    "@types/node": "20.19.43",
    "typescript": "7.0.2"
  }
}
