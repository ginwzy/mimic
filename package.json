{
  "name": "mimic",
  "version": "0.3.0",
  "description": "基于 jsdom 的浏览器环境回放框架 —— Profile/Shape 驱动,面向 JS 逆向反检测",
  "type": "module",
  "main": "./build/v2/src/v2/public.js",
  "types": "./build/v2/src/v2/public.d.ts",
  "exports": {
    ".": {
      "types": "./build/v2/src/v2/public.d.ts",
      "import": "./build/v2/src/v2/public.js",
      "default": "./build/v2/src/v2/public.js"
    },
    "./advanced": {
      "types": "./build/v2/src/v2/advanced.d.ts",
      "import": "./build/v2/src/v2/advanced.js",
      "default": "./build/v2/src/v2/advanced.js"
    },
    "./http": {
      "types": "./build/v2/src/v2/http/public.d.ts",
      "import": "./build/v2/src/v2/http/public.js",
      "default": "./build/v2/src/v2/http/public.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "mimic": "build/v2/src/v2/cli.js"
  },
  "files": [
    "build/v2/",
    "docs/v2-usage.md",
    "README.md",
    "LICENSE",
    "!**/*.test.js"
  ],
  "scripts": {
    "mimic": "node build/v2/src/v2/cli.js",
    "diff": "node build/v2/src/v2/cli.js diff",
    "build:v2": "node scripts/build-v2.js production",
    "build:v2:test": "node scripts/build-v2.js test",
    "generate:v2:shapes:compiled": "node scripts/generate-v2-shapes.js",
    "generate:v2:shapes": "npm run build:v2 && npm run generate:v2:shapes:compiled",
    "check:v2:shapes:compiled": "node scripts/generate-v2-shapes.js --check",
    "check:v2:shapes": "npm run build:v2 && npm run check:v2:shapes:compiled",
    "prepack": "npm run build:v2 && npm run check:v2:shapes:compiled && npm run check:data:compiled",
    "typecheck:v2": "tsc -p tsconfig.v2.test.json --noEmit",
    "test:v2": "npm run build:v2 && npm run build:v2:test && node --test build/v2-test/test/v2/*.test.js",
    "test": "npm run test:v2",
    "check:data:compiled": "node scripts/check-data.js",
    "check:data": "npm run build:v2 && npm run check:data:compiled",
    "check": "npm run typecheck:v2 && npm run check:v2:shapes && npm run check:data:compiled",
    "bench:v2": "npm run build:v2 && node build/v2/src/v2/quality/bench.js",
    "gate:v2:leak": "npm run build:v2 && node build/v2/src/v2/quality/leak.js"
  },
  "keywords": [
    "jsdom",
    "browser-environment",
    "fingerprint",
    "anti-detection",
    "js-reverse"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "ajv": "8.20.0",
    "jsdom": "29.1.1"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24.0.0"
  },
  "devDependencies": {
    "@types/jsdom": "28.0.3",
    "@types/node": "20.19.43",
    "typescript": "7.0.2"
  }
}
