{
  "name": "mimic",
  "version": "0.3.0",
  "description": "基于 jsdom 的浏览器环境回放框架 —— Profile/Shape 驱动,面向 JS 逆向反检测",
  "type": "module",
  "main": "./dist/src/public.js",
  "types": "./dist/src/public.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/public.d.ts",
      "import": "./dist/src/public.js",
      "default": "./dist/src/public.js"
    },
    "./advanced": {
      "types": "./dist/src/advanced.d.ts",
      "import": "./dist/src/advanced.js",
      "default": "./dist/src/advanced.js"
    },
    "./http": {
      "types": "./dist/src/http/public.d.ts",
      "import": "./dist/src/http/public.js",
      "default": "./dist/src/http/public.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "mimic": "dist/src/cli.js"
  },
  "files": [
    "dist/",
    "docs/usage.md",
    "README.md",
    "LICENSE",
    "!**/*.test.js"
  ],
  "scripts": {
    "mimic": "node dist/src/cli.js",
    "diff": "node dist/src/cli.js diff",
    "build": "node scripts/build.js production",
    "build:test": "node scripts/build.js test",
    "generate:shapes:compiled": "node scripts/generate-shapes.js",
    "generate:shapes": "npm run build && npm run generate:shapes:compiled",
    "check:shapes:compiled": "node scripts/generate-shapes.js --check",
    "check:shapes": "npm run build && npm run check:shapes:compiled",
    "prepack": "npm run build && npm run check:shapes:compiled && npm run check:data:compiled",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "test": "npm run build && npm run build:test && node --test build/test/test/*.test.js",
    "check:data:compiled": "node scripts/check-data.js",
    "check:data": "npm run build && npm run check:data:compiled",
    "check": "npm run typecheck && npm run check:shapes && npm run check:data:compiled",
    "bench": "npm run build && node dist/src/quality/bench.js",
    "gate:leak": "npm run build && node dist/src/quality/leak.js"
  },
  "keywords": [
    "jsdom",
    "browser-environment",
    "fingerprint",
    "anti-detection",
    "js-reverse"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "ajv": "8.20.0",
    "jsdom": "29.1.1"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24.0.0"
  },
  "devDependencies": {
    "@types/jsdom": "28.0.3",
    "@types/node": "20.19.43",
    "typescript": "7.0.2"
  }
}
