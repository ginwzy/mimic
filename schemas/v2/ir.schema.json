{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mimic.local/schema/v2/ir.json",
  "title": "Shape IR Operation",
  "oneOf": [
    { "$ref": "#/definitions/allocObject" },
    { "$ref": "#/definitions/allocFunction" },
    { "$ref": "#/definitions/allocProxy" },
    { "$ref": "#/definitions/proto" },
    { "$ref": "#/definitions/prop" },
    { "$ref": "#/definitions/drop" },
    { "$ref": "#/definitions/fn" },
    { "$ref": "#/definitions/order" }
  ],
  "definitions": {
    "path": {
      "type": "string",
      "pattern": "^window(?:\\.[A-Za-z_$][A-Za-z0-9_$]*)*$"
    },
    "ref": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["path"],
          "properties": { "path": { "$ref": "#/definitions/path" } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["node"],
          "properties": { "node": { "type": "string", "minLength": 1 } }
        }
      ]
    },
    "symbol": {
      "type": "string",
      "anyOf": [
        { "pattern": "^for:" },
        {
          "enum": ["asyncIterator", "hasInstance", "isConcatSpreadable", "iterator", "match", "matchAll", "replace", "search", "species", "split", "toPrimitive", "toStringTag", "unscopables"]
        }
      ]
    },
    "key": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["symbol"],
          "properties": { "symbol": { "$ref": "#/definitions/symbol" } }
        }
      ]
    },
    "storedValue": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["json"],
          "properties": {
            "json": { "$ref": "https://mimic.local/schema/v2/data.json#/definitions/value" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["ref"],
          "properties": { "ref": { "$ref": "#/definitions/ref" } }
        }
      ]
    },
    "desc": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "value", "writable", "enumerable", "configurable"],
          "properties": {
            "kind": { "const": "data" },
            "value": { "$ref": "#/definitions/storedValue" },
            "writable": { "type": "boolean" },
            "enumerable": { "type": "boolean" },
            "configurable": { "type": "boolean" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "enumerable", "configurable"],
          "properties": {
            "kind": { "const": "accessor" },
            "get": { "$ref": "#/definitions/ref" },
            "set": { "$ref": "#/definitions/ref" },
            "enumerable": { "type": "boolean" },
            "configurable": { "type": "boolean" }
          }
        }
      ]
    },
    "fnShape": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "length", "native", "constructable", "hasPrototype", "keys"],
      "properties": {
        "name": { "type": "string" },
        "length": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        "native": { "type": "boolean" },
        "constructable": { "type": "boolean" },
        "hasPrototype": { "type": "boolean" },
        "keys": { "type": "array", "uniqueItems": true, "items": { "type": "string" } }
      }
    },
    "allocObject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "id", "kind"],
      "properties": {
        "op": { "const": "alloc" },
        "id": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["object", "event"] }
      }
    },
    "allocFunction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "id", "kind", "shape"],
      "properties": {
        "op": { "const": "alloc" },
        "id": { "type": "string", "minLength": 1 },
        "kind": { "const": "function" },
        "shape": { "$ref": "#/definitions/fnShape" },
        "slot": { "type": "string", "minLength": 1 },
        "prototype": { "$ref": "#/definitions/ref" }
      },
      "if": {
        "type": "object",
        "required": ["prototype"],
        "properties": { "prototype": {} }
      },
      "then": {
        "type": "object",
        "properties": {
          "shape": {
            "type": "object",
            "properties": { "hasPrototype": { "const": true } }
          }
        }
      }
    },
    "allocProxy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "id", "kind", "source", "symbols"],
      "properties": {
        "op": { "const": "alloc" },
        "id": { "type": "string", "minLength": 1 },
        "kind": { "const": "proxy" },
        "source": { "$ref": "#/definitions/ref" },
        "symbols": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "proto": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "target", "value"],
      "properties": {
        "op": { "const": "proto" },
        "target": { "$ref": "#/definitions/ref" },
        "value": {
          "oneOf": [
            { "$ref": "#/definitions/ref" },
            { "type": "null" }
          ]
        }
      }
    },
    "prop": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "target", "key", "desc"],
      "properties": {
        "op": { "const": "prop" },
        "target": { "$ref": "#/definitions/ref" },
        "key": { "$ref": "#/definitions/key" },
        "desc": { "$ref": "#/definitions/desc" }
      }
    },
    "drop": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "target", "key"],
      "properties": {
        "op": { "const": "drop" },
        "target": { "$ref": "#/definitions/ref" },
        "key": { "$ref": "#/definitions/key" }
      }
    },
    "fn": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "target", "shape"],
      "dependencies": {
        "key": ["part"],
        "part": ["key"]
      },
      "properties": {
        "op": { "const": "fn" },
        "target": { "$ref": "#/definitions/ref" },
        "key": { "$ref": "#/definitions/key" },
        "part": { "enum": ["value", "get", "set"] },
        "shape": { "$ref": "#/definitions/fnShape" }
      }
    },
    "order": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "target", "keys"],
      "properties": {
        "op": { "const": "order" },
        "target": { "$ref": "#/definitions/ref" },
        "keys": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/definitions/key" } }
      }
    }
  }
}
