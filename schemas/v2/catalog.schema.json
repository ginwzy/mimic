{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mimic.local/schema/v2/catalog.json",
  "title": "Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "id", "hash", "shapes"],
  "properties": {
    "schema": { "const": 2 },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9.-]*$" },
    "hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "shapes": {
      "type": "array",
      "items": { "$ref": "https://mimic.local/schema/v2/shape.json" }
    }
  }
}
